# A NestJS backend nyilvános alap-URL-je (böngészőből is elérhető → NEXT_PUBLIC_ prefix).
# Lokális fejlesztés: a backend a 3001-es porton, "api" globális prefixszel fut.
# Docker compose alatt a service-név alapján is feloldható (pl. http://backend:3001),
# de mivel ez a változó a böngészőbe kerül, a hostról elérhető címet add meg.
NEXT_PUBLIC_API_URL=http://localhost:3001
