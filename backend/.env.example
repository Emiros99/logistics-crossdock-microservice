# ── Cross-Docking API backend — környezeti változók ──
# Másold .env-be:  cp .env.example .env   (PowerShell: Copy-Item .env.example .env)

# HTTP
PORT=3001
CORS_ORIGIN=http://localhost:3000

# PostgreSQL (Prisma) — a csomag hiteles állapota (source of truth)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crossdock

# MongoDB (Mongoose) — append-only mozgástörténet
MONGO_URI=mongodb://localhost:27017/crossdock_tracking

# Redis — cache-aside + BullMQ backend
# A docker-compose a Redist a HOST 6380-as portjára mappeli (a 6379 fejlesztői
# gépen gyakran foglalt); konténerhálózaton belül a cím redis:6379 marad.
REDIS_HOST=localhost
REDIS_PORT=6380

# Cache TTL (másodperc) a tracking:{trackingNumber} kulcsra — biztonsági háló
CACHE_TRACKING_TTL=30

# BullMQ NOTIFY_LAST_MILE_COURIER job retry politika
NOTIFY_ATTEMPTS=5
NOTIFY_BACKOFF_MS=1000
